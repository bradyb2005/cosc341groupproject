<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F6"
    android:id="@+id/main"
    android:fitsSystemWindows="true"
    tools:context=".ConsistencyCalendar">

    <!-- Top Navigation -->
    <LinearLayout
        android:id="@+id/backBtnBox"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/box_back"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="2dp">
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#000000" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/addMedBtnBox"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/box_outline"
        android:backgroundTint="#E1F5FE"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toStartOf="@id/todayBtnBox"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="2dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Med"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/todayBtnBox"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/box_today"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="2dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="#000000"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Title Area with colored accent -->
    <LinearLayout
        android:id="@+id/titleGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/backBtnBox">

        <TextView
            android:id="@+id/calendarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consistency Calendar"
            android:textColor="#1A237E"
            android:textSize="28sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/titleUnderline"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#1A237E" />
    </LinearLayout>

    <!-- Month Navigation with soft background -->
    <LinearLayout
        android:id="@+id/monthNav"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/box_outline"
        android:backgroundTint="#FFFFFF"
        android:padding="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleGroup"
        android:elevation="1dp">

        <FrameLayout
            android:id="@+id/prevMonthBox"
            android:layout_width="40dp"
            android:layout_height="35dp"
            android:background="@drawable/box_outline"
            android:backgroundTint="#EEEEEE">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="←"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/currentMonth"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="April"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/nextMonthBox"
            android:layout_width="40dp"
            android:layout_height="35dp"
            android:background="@drawable/box_outline"
            android:backgroundTint="#EEEEEE">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="→"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

    <!-- Days Header with background -->
    <LinearLayout
        android:id="@+id/daysHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:background="#E0E0E0"
        android:paddingVertical="4dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/monthNav">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="S" android:textColor="#D32F2F" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="M" android:textColor="#000000" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T" android:textColor="#000000" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="W" android:textColor="#000000" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T" android:textColor="#000000" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="F" android:textColor="#000000" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="S" android:textColor="#D32F2F" android:textStyle="bold" />
    </LinearLayout>

    <!-- Calendar Grid -->
    <GridView
        android:id="@+id/calendarGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:numColumns="7"
        android:verticalSpacing="1dp"
        android:horizontalSpacing="1dp"
        android:background="#000000"
        android:padding="1dp"
        app:layout_constraintBottom_toTopOf="@+id/detailsPanel"
        app:layout_constraintTop_toBottomOf="@id/daysHeader"
        android:elevation="2dp" />

    <!-- Details Panel -->
    <FrameLayout
        android:id="@+id/detailsPanel"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/thick_green_box"
        app:layout_constraintBottom_toTopOf="@id/btnEmergencyOptions"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/detailsContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/detailMedication"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aspirin"
                android:textColor="#000000"
                android:textSize="28sp"
                android:textStyle="bold" />

            <View
                android:layout_width="120dp"
                android:layout_height="2dp"
                android:layout_marginVertical="6dp"
                android:background="#000000" />

            <TextView
                android:id="@+id/detailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Taken at 9:01AM"
                android:textColor="#000000"
                android:textSize="22sp" />

        </LinearLayout>
    </FrameLayout>

    <!-- Persistent Emergency Button -->
    <LinearLayout
        android:id="@+id/btnEmergencyOptions"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/btn_yellow"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★ EMERGENCY OPTIONS"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
